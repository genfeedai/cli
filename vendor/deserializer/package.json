{
  "description": "JSON:API deserializer for Genfeed.ai API responses",
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "name": "@genfeedai/deserializer",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc --build --force",
    "typecheck": "tsc --noEmit"
  },
  "types": "./src/index.ts",
  "version": "1.0.0"
}
